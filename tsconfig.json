{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ES2022",
        "moduleResolution": "Node", 
        "allowJs": true,
        "esModuleInterop": true,
        "strict": false,
        "skipLibCheck": true,
    },
    "ts-node": {
        "esm": true,
        "experimentalSpecifierResolution": "node"
    },
    "outDir": "./dist",
    "forceConsistentCasingInFileNames": true,
}

